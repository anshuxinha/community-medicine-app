{
    "hosting": {
        "public": "docs",
        "ignore": [
            "firebase.json",
            "**/.*"
        ],
        "rewrites": [
            {
                "source": "/privacy",
                "destination": "/privacy.html"
            }
        ]
    },
    "firestore": {
        "rules": "firestore.rules"
    },
    "functions": [
        {
            "source": "functions",
            "codebase": "default",
            "ignore": [
                "node_modules",
                ".git",
                "firebase-debug.log",
                "firebase-debug.*.log",
                "*.local"
            ]
        }
    ]
}