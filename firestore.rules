rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // Allow admin to list users for push token collection
      allow read: if request.auth != null && request.auth.token.isAdmin == true;

      // Allow any user to update another user's document ONLY to reward a referral
      allow update: if request.auth != null 
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalReferrals', 'premiumExpiryDate', 'isPremium'])
        && request.resource.data.isPremium == true
        && (
          (resource.data.totalReferrals == null && request.resource.data.totalReferrals == 1)
          || (request.resource.data.totalReferrals != null && request.resource.data.totalReferrals == resource.data.totalReferrals + 1)
        );

      match /highlights/{contentKey} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /annotations/{contentKey} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /libraryContentOverrides/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.isAdmin == true;
    }

    match /libraryReviewSuggestions/{docId} {
      allow read, write: if request.auth != null && request.auth.token.isAdmin == true;
    }

    match /libraryReviewMeta/{docId} {
      allow read, write: if request.auth != null && request.auth.token.isAdmin == true;
    }

    match /videos/{videoId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.isAdmin == true;
    }

    match /videoDoubts/{doubtId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == "under_review";
      allow delete: if request.auth != null
        && (request.auth.token.isAdmin == true || resource.data.userId == request.auth.uid);
      allow update: if request.auth != null
        && (
          request.auth.token.isAdmin == true
          || (
            resource.data.userId == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['authorPushToken'])
          )
          || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['upvotedBy', 'replies'])
        );
    }

    // --- Added for Coupons ---
    match /coupons/{couponId} {
      // Users need to read coupon details to validate them
      allow read: if request.auth != null;

      // Allow users to update ONLY the usageCount field during a purchase transaction
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usageCount']);

      // Admins have full control to create/delete coupons
      allow write: if request.auth != null && request.auth.token.isAdmin == true;
    }

    // --- Added for Topic Illustrations ---
    match /topicIllustrations/{docId} {
      // Authenticated users can read illustrations
      allow read: if request.auth != null;
      // Only admins can update or create illustrations
      allow write: if request.auth != null && request.auth.token.isAdmin == true;
    }

    // --- Added for Referrals ---
    match /referrals/{referralId} {
      allow read: if request.auth != null 
        && (resource == null || resource.data.referrerUid == request.auth.uid || resource.data.refereeUid == request.auth.uid);
      allow create: if request.auth != null 
        && (request.resource.data.refereeUid == request.auth.uid || request.resource.data.referrerUid == request.auth.uid);
      allow update: if request.auth != null
        && resource.data.referrerUid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rewardGranted', 'status']);
    }

    // --- Added for Referral Codes registry ---
    match /referralCodes/{code} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.resource.data.ownerUid == request.auth.uid;
    }
  }
}
